# Postgres 接続文字列
# ローカル: docker-compose.yml の Postgres を使う
# 本番: Vercel Postgres (Neon) の接続文字列
DATABASE_URL=postgresql://katazuketta:katazuketta@localhost:5432/katazuketta

# NextAuth
# AUTH_SECRET は `openssl rand -base64 32` で生成
AUTH_SECRET=
# ローカル以外では本番 URL を指定 (例: https://katazuketta.vercel.app)
AUTH_URL=http://localhost:3000

# Google OAuth (https://console.cloud.google.com/ で発行)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# 招待制ホワイトリスト (カンマ区切り、空なら無制限)
# ALLOWED_EMAILS=user1@example.com,user2@example.com
